{
  "name": "bucksmanagerandroid",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-constants": "^56.0.18",
    "expo-dev-client": "~56.0.0",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-print": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.2.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "test": "node --no-warnings --test tests/*.test.mjs",
    "test:watch": "node --watch --no-warnings --test tests/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=75 --test-coverage-functions=85 --test-coverage-include=src/api/*.ts --test-coverage-include=src/data/*.ts --test-coverage-include=src/domain/*.ts --test-coverage-include=src/utils/*.ts --no-warnings --test tests/*.test.mjs",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "node scripts/check-format.mjs",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage",
    "hooks:install": "git config core.hooksPath .githooks",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android.ps1",
    "android:build-dev": "eas build -p android --profile development",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "private": true
}
