{
  "expo": {
    "name": "Bucks Manager",
    "slug": "bucks-manager-android",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-bucks.png",
    "userInterfaceStyle": "dark",
    "scheme": "com.josev.bucksmanager",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.josev.bucksmanager"
    },
    "android": {
      "package": "com.josev.bucksmanager",
      "adaptiveIcon": {
        "backgroundColor": "#050E0B",
        "foregroundImage": "./assets/android-icon-foreground-bucks.png",
        "backgroundImage": "./assets/android-icon-background-bucks.png",
        "monochromeImage": "./assets/android-icon-monochrome-bucks.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.josev.bucksmanager",
              "pathPrefix": "/oauthredirect"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon-bucks.png"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-bucks.png",
          "resizeMode": "contain",
          "backgroundColor": "#050E0B"
        }
      ]
    ],
    "owner": "jose-vass",
    "extra": {
      "eas": {
        "projectId": "3d5e761d-91e2-455f-993f-be80f182ea36"
      }
    }
  }
}
